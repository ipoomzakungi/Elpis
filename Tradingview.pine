//@version=6
strategy("14-Indicator Status Dashboard Strategy", overlay = true, pyramiding = 3, initial_capital = 100000, default_qty_type = strategy.fixed, default_qty_value = 1, commission_type = strategy.commission.percent, commission_value = 0.05, slippage = 1, risk_free_rate = 2.0, margin_long = 100, margin_short = 100, process_orders_on_close = true, calc_on_order_fills = true, dynamic_requests = true)

// Strategy declaration defaults above are realistic starting values.
// TradingView requires commission, slippage, initial capital, pyramiding, and risk_free_rate
// to be set in strategy() or changed from Strategy Properties, not from runtime input values.

// Status constants.
STATUS_UP = "UP"
STATUS_LOW = "LOW"
STATUS_MID = "MID"
STATUS_RANGE = "RANGE"
STATUS_HIGH = "HIGH"
SIGNAL_BUY = "BUY BIAS"
SIGNAL_SELL = "SELL BIAS"

SIZE_FIXED = "Fixed quantity"
SIZE_PERCENT = "Percent of equity"
EXIT_DON = "Donchian Bands"
EXIT_ENV = "ENV Bands"
EXIT_ATR = "ATR Multiple"
GRID_SRC_DON = "Donchian Middle"
GRID_SRC_SD = "SD Basis"
GRID_SRC_EMA = "EMA"
GRID_SRC_VWAP = "Session VWAP if available"
CLOSE_CROSS = "Cross Middle"
CLOSE_TOUCH = "Touch Middle"
LADDER_REJECT = "RejectionMarket"
LADDER_LIMIT = "LimitLadder"

ID_GL1 = "GL_2_0"
ID_GL2 = "GL_2_5"
ID_GL3 = "GL_3_0"
ID_GS1 = "GS_2_0"
ID_GS2 = "GS_2_5"
ID_GS3 = "GS_3_0"

// Input groups.
GROUP_VIS_LINES = "Visuals - Lines"
GROUP_VIS_BANDS = "Visuals - Bands"
GROUP_MA = "1) MA - EMA"
GROUP_STO = "2) STO - Stochastic"
GROUP_SAR = "3) SAR"
GROUP_SD = "4) SD Bands"
GROUP_ENV = "5) ENV Bands"
GROUP_MACD = "6) MACD"
GROUP_RSI = "7) RSI"
GROUP_CCI = "8) CCI"
GROUP_DON = "9) DON"
GROUP_REGIME = "10) REGIME"
GROUP_VPI = "11) VPI"
GROUP_MTF = "12) MTF"
GROUP_SWEEP = "13) SWEEP"
GROUP_ADAPT = "14) ADAPT"
GROUP_SIGNAL = "Summary And Signals"
GROUP_STRATEGY = "Strategy Orders"
GROUP_GRID = "Dynamic Grid Range Engine"
GROUP_BIAS = "Asymmetric Bias Filters"
GROUP_LADDER = "3-Level SD Ladder Grid"
GROUP_RISK = "Basket Risk And Costs"
GROUP_FLIP = "Ladder Flip Logic"
GROUP_PERF = "Performance Panel"

// Default visuals match the existing style: MA OFF, SAR OFF, SD OFF, ENV OFF, DON ON.
showMA = input.bool(false, "MA line", group = GROUP_VIS_LINES)
showSAR = input.bool(false, "SAR dots", group = GROUP_VIS_LINES)
showSD = input.bool(false, "SD bands", group = GROUP_VIS_BANDS)
showENV = input.bool(false, "ENV bands", group = GROUP_VIS_BANDS)
showDON = input.bool(true, "DON bands", group = GROUP_VIS_BANDS)

// Indicator inputs.
maLen = input.int(50, "EMA length", minval = 1, group = GROUP_MA)

stoLen = input.int(14, "Length", minval = 1, group = GROUP_STO)
stoSmoothK = input.int(3, "K smoothing", minval = 1, group = GROUP_STO)
stoSmoothD = input.int(3, "D smoothing", minval = 1, group = GROUP_STO)

sarStart = input.float(0.02, "Start", minval = 0.001, step = 0.001, group = GROUP_SAR)
sarInc = input.float(0.02, "Increment", minval = 0.001, step = 0.001, group = GROUP_SAR)
sarMax = input.float(0.20, "Maximum", minval = 0.001, step = 0.01, group = GROUP_SAR)

sdLen = input.int(20, "SMA length", minval = 1, group = GROUP_SD)
sdMult = input.float(2.0, "Standard deviation multiplier", minval = 0.1, step = 0.1, group = GROUP_SD)
sdZThreshold = input.float(0.5, "Status z threshold", minval = 0.0, step = 0.1, group = GROUP_SD)

envLen = input.int(20, "SMA length", minval = 1, group = GROUP_ENV)
envPct = input.float(1.0, "Envelope percent", minval = 0.01, step = 0.01, group = GROUP_ENV)

macdFastLen = input.int(12, "Fast length", minval = 1, group = GROUP_MACD)
macdSlowLen = input.int(26, "Slow length", minval = 1, group = GROUP_MACD)
macdSignalLen = input.int(9, "Signal length", minval = 1, group = GROUP_MACD)

rsiLen = input.int(14, "Length", minval = 1, group = GROUP_RSI)
rsiUp = input.float(55.0, "UP threshold", step = 0.1, group = GROUP_RSI)
rsiLow = input.float(45.0, "LOW threshold", step = 0.1, group = GROUP_RSI)

cciLen = input.int(20, "Length", minval = 1, group = GROUP_CCI)
cciUp = input.float(100.0, "UP threshold", step = 1.0, group = GROUP_CCI)
cciLow = input.float(-100.0, "LOW threshold", step = 1.0, group = GROUP_CCI)

donLen = input.int(20, "Length", minval = 1, group = GROUP_DON)

regimeDiLen = input.int(14, "DI length", minval = 1, group = GROUP_REGIME)
regimeAdxSmooth = input.int(14, "ADX smoothing", minval = 1, group = GROUP_REGIME)
regimeAdxLevel = input.float(20.0, "ADX level", minval = 0.0, step = 0.5, group = GROUP_REGIME)
regimeAtrLen = input.int(14, "ATR length", minval = 1, group = GROUP_REGIME)
atrBaseLen = input.int(14, "ATR ratio baseline length", minval = 1, group = GROUP_REGIME)
regimeAtrRatioLevel = input.float(1.0, "ATR ratio threshold", minval = 0.0, step = 0.05, group = GROUP_REGIME)

vpiLen = input.int(20, "Length", minval = 1, group = GROUP_VPI)
vpiSmooth = input.int(5, "Smoothing", minval = 1, group = GROUP_VPI)
vpiUpper = input.float(0.10, "Upper threshold", step = 0.01, group = GROUP_VPI)
vpiLower = input.float(-0.10, "Lower threshold", step = 0.01, group = GROUP_VPI)

mtfTf = input.timeframe("1D", "Higher timeframe", group = GROUP_MTF)
mtfStrongVotes = input.int(4, "Strong vote threshold", minval = 1, maxval = 4, group = GROUP_MTF)

sweepLookback = input.int(20, "Lookback", minval = 2, group = GROUP_SWEEP)

adaptSqueezeLen = input.int(50, "Squeeze length", minval = 2, group = GROUP_ADAPT)
adaptBbMult = input.float(2.0, "Bollinger multiplier", minval = 0.1, step = 0.1, group = GROUP_ADAPT)
adaptRatioLevel = input.float(0.8, "Width ratio threshold", minval = 0.01, step = 0.01, group = GROUP_ADAPT)
adaptDonLen = input.int(50, "Donchian midpoint length", minval = 2, group = GROUP_ADAPT)

summaryUpLevel = input.float(0.35, "Summary UP threshold", step = 0.01, group = GROUP_SIGNAL)
summaryLowLevel = input.float(-0.35, "Summary LOW threshold", step = 0.01, group = GROUP_SIGNAL)
summaryRangeLevel = input.float(0.10, "Summary RANGE absolute threshold", minval = 0.0, step = 0.01, group = GROUP_SIGNAL)
signalBiasLevel = input.float(0.15, "Final bias threshold", minval = 0.0, step = 0.01, group = GROUP_SIGNAL)
confirmedOnly = input.bool(true, "Confirm signals on bar close", group = GROUP_SIGNAL)

executeOrders = input.bool(true, "Enable strategy orders", group = GROUP_STRATEGY)
sizeMode = input.string(SIZE_PERCENT, "Position size mode", options = [SIZE_PERCENT, SIZE_FIXED], group = GROUP_STRATEGY)
fixedQty = input.float(1.0, "Fixed quantity", minval = 0.0, step = 1.0, group = GROUP_STRATEGY)
equityPct = input.float(10.0, "Percent of equity", minval = 0.1, maxval = 100.0, step = 0.1, group = GROUP_STRATEGY)
requireBiasFilter = input.bool(false, "Require final bias for tactical entries", group = GROUP_STRATEGY)
exitMode = input.string(EXIT_ATR, "Stop/target source", options = [EXIT_ATR, EXIT_DON, EXIT_ENV], group = GROUP_STRATEGY)
exitAtrLen = input.int(14, "ATR exit length", minval = 1, group = GROUP_STRATEGY)
atrStopMult = input.float(2.0, "ATR stop multiple", minval = 0.1, step = 0.1, group = GROUP_STRATEGY)
atrTargetMult = input.float(3.0, "ATR target multiple", minval = 0.1, step = 0.1, group = GROUP_STRATEGY)

enableGridEngine = input.bool(true, "Enable grid engine", group = GROUP_GRID)
gridSource = input.string(GRID_SRC_DON, "Grid middle source", options = [GRID_SRC_DON, GRID_SRC_SD, GRID_SRC_EMA, GRID_SRC_VWAP], group = GROUP_GRID)
gridSdLen = input.int(50, "Grid SD length", minval = 5, group = GROUP_GRID)
entrySd = input.float(1.25, "Legacy entry SD", step = 0.05, group = GROUP_GRID)
stopSd = input.float(2.25, "Legacy stop SD", step = 0.05, group = GROUP_GRID)
noTradeSd = input.float(0.50, "No-trade SD", step = 0.05, group = GROUP_GRID)
useTrendFilter = input.bool(true, "Use trend filter", group = GROUP_GRID)
maxAdxForMeanReversion = input.float(25.0, "Max ADX for mean reversion", step = 0.5, group = GROUP_GRID)
useSweepConfirmation = input.bool(true, "Use sweep confirmation", group = GROUP_GRID)
closeAtMiddleMode = input.string(CLOSE_CROSS, "Close at middle mode", options = [CLOSE_CROSS, CLOSE_TOUCH], group = GROUP_GRID)
useOneTradeOnly = input.bool(true, "One trade only", group = GROUP_GRID)
allowFlipOnZoneBreak = input.bool(false, "Legacy grid flip on zone break", group = GROUP_GRID)
fixedGoldStopCapPoints = input.float(0.0, "Fixed gold stop cap points", minval = 0.0, step = 0.1, tooltip = "0 disables fixed cap; otherwise cap stop distance in XAUUSD points", group = GROUP_GRID)
minBarsBetweenTrades = input.int(5, "Min bars between trades", minval = 0, group = GROUP_GRID)
showGridLines = input.bool(true, "Show grid lines", group = GROUP_GRID)

// Asymmetric bias inputs.
enableAsymBias = input.bool(true, "Enable asymmetric bias", group = GROUP_BIAS)
biasHtfTf = input.timeframe("240", "Bias HTF timeframe", group = GROUP_BIAS)
macroTf = input.timeframe("240", "Macro timeframe", group = GROUP_BIAS)
dxySymbol = input.symbol("TVC:DXY", "DXY symbol", group = GROUP_BIAS)
us10ySymbol = input.symbol("TVC:US10Y", "US10Y symbol", group = GROUP_BIAS)
biasUseFinalSignal = input.bool(true, "Use final dashboard signal", group = GROUP_BIAS)
biasUseHtfTrend = input.bool(true, "Use HTF trend", group = GROUP_BIAS)
biasUseDxy = input.bool(true, "Use DXY", group = GROUP_BIAS)
biasUseUs10y = input.bool(true, "Use US10Y", group = GROUP_BIAS)
longBiasMinScore = input.int(2, "Long bias min score", minval = 0, maxval = 5, group = GROUP_BIAS)
shortBiasMinScore = input.int(3, "Short bias min score", minval = 0, maxval = 5, group = GROUP_BIAS)
longBiasSizeMult = input.float(1.00, "Long bias size multiplier", minval = 0.0, step = 0.05, group = GROUP_BIAS)
shortBiasSizeMult = input.float(0.75, "Short bias size multiplier", minval = 0.0, step = 0.05, group = GROUP_BIAS)

// Ladder grid inputs.
enableLadderGrid = input.bool(true, "Enable ladder grid", group = GROUP_LADDER)
entryMode = input.string(LADDER_REJECT, "Entry mode", options = [LADDER_REJECT, LADDER_LIMIT], group = GROUP_LADDER)
ladderSd1 = input.float(2.0, "Level 1 SD", step = 0.05, group = GROUP_LADDER)
ladderSd2 = input.float(2.5, "Level 2 SD", step = 0.05, group = GROUP_LADDER)
ladderSd3 = input.float(3.0, "Level 3 SD", step = 0.05, group = GROUP_LADDER)
ladderWeight1 = input.float(0.20, "Level 1 weight", minval = 0.0, step = 0.01, group = GROUP_LADDER)
ladderWeight2 = input.float(0.30, "Level 2 weight", minval = 0.0, step = 0.01, group = GROUP_LADDER)
ladderWeight3 = input.float(0.50, "Level 3 weight", minval = 0.0, step = 0.01, group = GROUP_LADDER)
targetOffsetSd = input.float(0.20, "Target offset SD", step = 0.05, group = GROUP_LADDER)
partialCutSd = input.float(3.25, "Partial cut SD", step = 0.05, group = GROUP_LADDER)
softStopSd = input.float(3.15, "Soft stop SD", step = 0.05, group = GROUP_LADDER)
emergencyStopSd = input.float(3.60, "Emergency stop SD", step = 0.05, group = GROUP_LADDER)
stopConfirmBars = input.int(1, "Stop confirm bars", minval = 1, group = GROUP_LADDER)
maxBarsInTrade = input.int(0, "Max bars in trade (0 disables)", minval = 0, group = GROUP_LADDER)
ladderAllowLongs = input.bool(true, "Allow ladder longs", group = GROUP_LADDER)
ladderAllowShorts = input.bool(true, "Allow ladder shorts", group = GROUP_LADDER)
ladderUseTrendFilter = input.bool(false, "Use ladder ADX filter", group = GROUP_LADDER)
ladderMaxAdx = input.float(35.0, "Ladder max ADX", step = 0.5, group = GROUP_LADDER)
ladderUseSweepConfirmation = input.bool(false, "Use ladder sweep confirmation", group = GROUP_LADDER)
ladderCancelOppositeOrders = input.bool(true, "Cancel opposite ladder orders", group = GROUP_LADDER)

// Fee-aware and basket risk inputs.
useFeeAwareSizing = input.bool(true, "Use fee-aware trade filter", group = GROUP_RISK)
makerFeePct = input.float(0.02, "Maker fee %", minval = 0.0, step = 0.01, group = GROUP_RISK)
takerFeePct = input.float(0.05, "Taker fee %", minval = 0.0, step = 0.01, group = GROUP_RISK)
spreadPointsInput = input.float(0.00, "Spread points", minval = 0.0, step = 0.01, group = GROUP_RISK)
slippagePointsInput = input.float(0.00, "Slippage points", minval = 0.0, step = 0.01, group = GROUP_RISK)
minRewardCostMultiple = input.float(4.0, "Min reward/cost multiple", minval = 0.0, step = 0.1, group = GROUP_RISK)
minRewardRiskRatio = input.float(0.9, "Min reward/risk ratio", minval = 0.0, step = 0.05, group = GROUP_RISK)
conservativeExitAsTaker = input.bool(true, "Conservative exit as taker", group = GROUP_RISK)
useBasketRiskSizing = input.bool(true, "Use basket risk sizing", group = GROUP_RISK)
basketRiskPct = input.float(0.35, "Basket risk %", minval = 0.0, step = 0.05, group = GROUP_RISK)
maxNotionalPct = input.float(10.0, "Max notional %", minval = 0.0, step = 0.5, group = GROUP_RISK)
maxPositionContractsHardCap = input.float(0.0, "Hard max position size (0 disables)", minval = 0.0, step = 1.0, group = GROUP_RISK)

// Secondary hard guard uses a very high cap when disabled because strategy.risk requires a simple value.
strategy.risk.max_position_size(maxPositionContractsHardCap > 0.0 ? maxPositionContractsHardCap : 1000000000.0)

// Flip inputs.
allowSameBarFlip = input.bool(false, "Allow same-bar flip", group = GROUP_FLIP)
flipRequiresBias = input.bool(true, "Flip requires opposite bias", group = GROUP_FLIP)
flipOnZoneBreak = input.bool(false, "Flip on zone break", group = GROUP_FLIP)

riskFreeRateInput = input.float(2.0, "risk_free_rate for custom Sharpe (%)", step = 0.1, group = GROUP_PERF)
customSharpeLen = input.int(100, "Custom Sharpe return length", minval = 2, group = GROUP_PERF)

// Helper functions.
f_safeDiv(float _num, float _den, float _fallback) =>
    not na(_num) and not na(_den) and _den != 0.0 ? _num / _den : _fallback

f_minNotNa(float _a, float _b) =>
    na(_a) ? _b : na(_b) ? _a : math.min(_a, _b)

f_maxNotNa(float _a, float _b) =>
    na(_a) ? _b : na(_b) ? _a : math.max(_a, _b)

f_score(_status) =>
    _status == STATUS_UP or _status == STATUS_HIGH ? 1 : _status == STATUS_LOW ? -1 : 0

f_upCount(_status) =>
    _status == STATUS_UP or _status == STATUS_HIGH ? 1 : 0

f_lowCount(_status) =>
    _status == STATUS_LOW ? 1 : 0

f_statusText(_status) =>
    _status == STATUS_UP ? STATUS_UP : _status == STATUS_LOW ? STATUS_LOW : _status == STATUS_HIGH ? STATUS_HIGH : _status == STATUS_RANGE ? STATUS_RANGE : _status == SIGNAL_BUY ? SIGNAL_BUY : _status == SIGNAL_SELL ? SIGNAL_SELL : STATUS_MID

f_statusColor(_status) =>
    _status == STATUS_UP or _status == STATUS_HIGH or _status == SIGNAL_BUY ? color.new(color.lime, 15) : _status == STATUS_LOW or _status == SIGNAL_SELL ? color.new(color.red, 15) : _status == STATUS_RANGE ? color.new(color.orange, 15) : color.new(color.gray, 20)

f_price(float _value) =>
    na(_value) ? "n/a" : str.tostring(_value, format.mintick)

f_num(float _value) =>
    na(_value) ? "n/a" : str.tostring(_value, "#.##")

f_pct(float _value) =>
    na(_value) ? "n/a" : str.tostring(_value, "#.##") + "%"

f_boolText(bool _value) =>
    _value ? "ON" : "OFF"

f_macdHist(_src, _fast, _slow, _signal) =>
    [_macd, _sig, _hist] = ta.macd(_src, _fast, _slow, _signal)
    _hist

f_orderQty(_mode, _fixedQty, _equityPct) =>
    _contractValue = close * syminfo.pointvalue
    _mode == SIZE_FIXED ? _fixedQty : _contractValue > 0.0 and strategy.equity > 0.0 ? (strategy.equity * _equityPct * 0.01) / _contractValue : 0.0

f_hasOpenEntry(string entryId) =>
    bool found = false
    if strategy.opentrades > 0
        for i = 0 to strategy.opentrades - 1
            if strategy.opentrades.entry_id(i) == entryId
                found := true
    found

f_roundTripCostDollar(float entryPx, float exitPx, float qty, bool isLimitEntry, bool isLimitExit) =>
    float entryFeePct = isLimitEntry ? makerFeePct : takerFeePct
    float exitFeePct = isLimitExit ? makerFeePct : takerFeePct
    if conservativeExitAsTaker
        exitFeePct := takerFeePct
    feeDollar = qty * ((entryPx * entryFeePct * 0.01) + (exitPx * exitFeePct * 0.01))
    spreadDollar = qty * spreadPointsInput
    slipDollar = qty * slippagePointsInput
    feeDollar + spreadDollar + slipDollar

f_rewardCostOk(float rewardDollar, float costDollar) =>
    not useFeeAwareSizing or (not na(rewardDollar) and rewardDollar > 0.0 and (costDollar <= 0.0 or rewardDollar / costDollar >= minRewardCostMultiple))

f_rewardRiskOk(float rewardDollar, float riskDollar) =>
    not useFeeAwareSizing or (not na(rewardDollar) and not na(riskDollar) and rewardDollar > 0.0 and riskDollar > 0.0 and rewardDollar / riskDollar >= minRewardRiskRatio)

f_cancelLongBasket() =>
    strategy.cancel(ID_GL1)
    strategy.cancel(ID_GL2)
    strategy.cancel(ID_GL3)
    true

f_cancelShortBasket() =>
    strategy.cancel(ID_GS1)
    strategy.cancel(ID_GS2)
    strategy.cancel(ID_GS3)
    true

f_closeLongBasket(string _comment) =>
    strategy.close(ID_GL1, comment = _comment)
    strategy.close(ID_GL2, comment = _comment)
    strategy.close(ID_GL3, comment = _comment)
    true

f_closeShortBasket(string _comment) =>
    strategy.close(ID_GS1, comment = _comment)
    strategy.close(ID_GS2, comment = _comment)
    strategy.close(ID_GS3, comment = _comment)
    true

f_renderRow(_table, _row, _name, _status, _detail) =>
    _bg = f_statusColor(_status)
    table.cell(_table, 0, _row, _name, text_color = color.white, bgcolor = color.new(color.black, 0), text_halign = text.align_left, text_size = size.small)
    table.cell(_table, 1, _row, f_statusText(_status), text_color = color.white, bgcolor = _bg, text_halign = text.align_center, text_size = size.small)
    table.cell(_table, 2, _row, _detail, text_color = color.white, bgcolor = color.new(color.black, 0), text_halign = text.align_left, text_size = size.small)
    true

f_renderInfoRow(_table, _row, _name, _detail) =>
    table.cell(_table, 0, _row, _name, text_color = color.white, bgcolor = color.new(color.black, 0), text_halign = text.align_left, text_size = size.small)
    table.cell(_table, 1, _row, "", text_color = color.white, bgcolor = color.new(color.black, 0), text_halign = text.align_center, text_size = size.small)
    table.cell(_table, 2, _row, _detail, text_color = color.white, bgcolor = color.new(color.black, 0), text_halign = text.align_left, text_size = size.small)
    true

// Timeframe guards keep requested HTF filters from accidentally sampling lower timeframes.
chartSeconds = timeframe.in_seconds()
mtfSeconds = timeframe.in_seconds(mtfTf)
biasHtfSeconds = timeframe.in_seconds(biasHtfTf)
macroSeconds = timeframe.in_seconds(macroTf)

if not na(chartSeconds) and not na(mtfSeconds) and mtfSeconds < chartSeconds
    runtime.error("Selected MTF timeframe must be equal to or higher than the chart timeframe.")

if not na(chartSeconds) and not na(biasHtfSeconds) and biasHtfSeconds < chartSeconds
    runtime.error("Selected bias HTF timeframe must be equal to or higher than the chart timeframe.")

if not na(chartSeconds) and not na(macroSeconds) and macroSeconds < chartSeconds
    runtime.error("Selected macro timeframe must be equal to or higher than the chart timeframe.")

// 1) MA.
ema50 = ta.ema(close, maLen)
maStatus = not na(ema50) ? (close > ema50 ? STATUS_UP : close < ema50 ? STATUS_LOW : STATUS_MID) : STATUS_MID

// 2) STO.
stoRawK = ta.stoch(close, high, low, stoLen)
stoK = ta.sma(stoRawK, stoSmoothK)
stoD = ta.sma(stoK, stoSmoothD)
stoReady = not na(stoK) and not na(stoD)
stoStatus = stoReady ? (stoK > stoD and stoK >= 50.0 ? STATUS_UP : stoK < stoD and stoK <= 50.0 ? STATUS_LOW : STATUS_MID) : STATUS_MID

// 3) SAR.
sarValue = ta.sar(sarStart, sarInc, sarMax)
sarStatus = not na(sarValue) ? (close > sarValue ? STATUS_UP : close < sarValue ? STATUS_LOW : STATUS_MID) : STATUS_MID

// 4) SD.
sdBasis = ta.sma(close, sdLen)
sdDev = ta.stdev(close, sdLen)
sdUpper = sdBasis + sdDev * sdMult
sdLower = sdBasis - sdDev * sdMult
sdReady = not na(sdBasis) and not na(sdDev) and sdDev != 0.0
sdZ = f_safeDiv(close - sdBasis, sdDev, 0.0)
sdStatus = sdReady ? (sdZ >= sdZThreshold ? STATUS_HIGH : sdZ <= -sdZThreshold ? STATUS_LOW : STATUS_MID) : STATUS_MID

// 5) ENV.
envBasis = ta.sma(close, envLen)
envUpper = envBasis * (1.0 + envPct * 0.01)
envLower = envBasis * (1.0 - envPct * 0.01)
envStatus = not na(envBasis) ? (close > envBasis ? STATUS_UP : close < envBasis ? STATUS_LOW : STATUS_MID) : STATUS_MID

// 6) MACD.
[macdLine, macdSignal, macdHist] = ta.macd(close, macdFastLen, macdSlowLen, macdSignalLen)
macdReady = not na(macdLine) and not na(macdSignal) and not na(macdHist)
macdStatus = macdReady ? (macdLine > macdSignal and macdHist >= 0.0 ? STATUS_UP : macdLine < macdSignal and macdHist <= 0.0 ? STATUS_LOW : STATUS_MID) : STATUS_MID

// 7) RSI.
rsiValue = ta.rsi(close, rsiLen)
rsiStatus = not na(rsiValue) ? (rsiValue > rsiUp ? STATUS_UP : rsiValue < rsiLow ? STATUS_LOW : STATUS_MID) : STATUS_MID

// 8) CCI.
cciValue = ta.cci(hlc3, cciLen)
cciStatus = not na(cciValue) ? (cciValue > cciUp ? STATUS_UP : cciValue < cciLow ? STATUS_LOW : STATUS_MID) : STATUS_MID

// 9) DON.
donUpper = ta.highest(high, donLen)
donLower = ta.lowest(low, donLen)
donMid = (donUpper + donLower) * 0.5
donStatus = not na(donMid) ? (close > donMid ? STATUS_UP : close < donMid ? STATUS_LOW : STATUS_MID) : STATUS_MID

// 10) REGIME.
[plusDI, minusDI, adxValue] = ta.dmi(regimeDiLen, regimeAdxSmooth)
regimeAtr = ta.atr(regimeAtrLen)
regimeAtrBase = ta.sma(regimeAtr, atrBaseLen)
atrRatio = f_safeDiv(regimeAtr, regimeAtrBase, 0.0)
regimeReady = not na(adxValue) and not na(plusDI) and not na(minusDI) and not na(atrRatio)
regimeStatus = regimeReady ? (adxValue < regimeAdxLevel and atrRatio < regimeAtrRatioLevel ? STATUS_RANGE : adxValue >= regimeAdxLevel and plusDI > minusDI and atrRatio >= regimeAtrRatioLevel ? STATUS_UP : adxValue >= regimeAdxLevel and minusDI > plusDI and atrRatio >= regimeAtrRatioLevel ? STATUS_LOW : STATUS_MID) : STATUS_MID

// 11) VPI.
vol = nz(volume, 0.0)
signedVol = close > open ? vol : close < open ? -vol : 0.0
avgVolume = ta.sma(vol, vpiLen)
hasVolume = not na(avgVolume) and avgVolume > 0.0
vpiRaw = f_safeDiv(ta.sma(signedVol, vpiLen), avgVolume, 0.0)
vpi = ta.ema(vpiRaw, vpiSmooth)
vpiStatus = hasVolume ? (vpi > vpiUpper ? STATUS_UP : vpi < vpiLower ? STATUS_LOW : STATUS_MID) : STATUS_MID

// 12) MTF. Confirmed HTF request pattern: expression[1] with lookahead_on.
dClose = request.security(syminfo.tickerid, mtfTf, close[1], lookahead = barmerge.lookahead_on)
dEma50 = request.security(syminfo.tickerid, mtfTf, ta.ema(close, maLen)[1], lookahead = barmerge.lookahead_on)
dSar = request.security(syminfo.tickerid, mtfTf, ta.sar(sarStart, sarInc, sarMax)[1], lookahead = barmerge.lookahead_on)
dMacdHist = request.security(syminfo.tickerid, mtfTf, f_macdHist(close, macdFastLen, macdSlowLen, macdSignalLen)[1], lookahead = barmerge.lookahead_on)
dRsi = request.security(syminfo.tickerid, mtfTf, ta.rsi(close, rsiLen)[1], lookahead = barmerge.lookahead_on)

mtfUpVotes = (not na(dClose) and not na(dEma50) and dClose > dEma50 ? 1 : 0) + (not na(dClose) and not na(dSar) and dClose > dSar ? 1 : 0) + (not na(dMacdHist) and dMacdHist > 0.0 ? 1 : 0) + (not na(dRsi) and dRsi > 50.0 ? 1 : 0)
mtfLowVotes = (not na(dClose) and not na(dEma50) and dClose < dEma50 ? 1 : 0) + (not na(dClose) and not na(dSar) and dClose < dSar ? 1 : 0) + (not na(dMacdHist) and dMacdHist < 0.0 ? 1 : 0) + (not na(dRsi) and dRsi < 50.0 ? 1 : 0)
mtfStatus = mtfUpVotes >= mtfStrongVotes ? STATUS_UP : mtfLowVotes >= mtfStrongVotes ? STATUS_LOW : STATUS_MID

// 13) SWEEP.
priorHigh = ta.highest(high[1], sweepLookback - 1)
priorLow = ta.lowest(low[1], sweepLookback - 1)
highTrap = not na(priorHigh) and high > priorHigh and close < priorHigh
lowTrap = not na(priorLow) and low < priorLow and close > priorLow
sweepConflict = highTrap and lowTrap
sweepStatus = sweepConflict ? STATUS_MID : highTrap ? STATUS_LOW : lowTrap ? STATUS_UP : STATUS_MID
sweepText = sweepConflict ? "CONFLICT" : highTrap ? "HIGH TRAP" : lowTrap ? "LOW TRAP" : "NO SWEEP"

// 14) ADAPT.
adaptBasisBB = ta.sma(close, adaptSqueezeLen)
adaptDevBB = ta.stdev(close, adaptSqueezeLen) * adaptBbMult
adaptUpperBB = adaptBasisBB + adaptDevBB
adaptLowerBB = adaptBasisBB - adaptDevBB
adaptBbWidth = not na(adaptBasisBB) and adaptBasisBB != 0.0 ? (adaptUpperBB - adaptLowerBB) / math.abs(adaptBasisBB) : na
adaptWidthBase = ta.sma(adaptBbWidth, adaptSqueezeLen)
adaptWidthRatio = f_safeDiv(adaptBbWidth, adaptWidthBase, na)
adaptDonUpper = ta.highest(high, adaptDonLen)
adaptDonLower = ta.lowest(low, adaptDonLen)
adaptDonMid = (adaptDonUpper + adaptDonLower) * 0.5
squeezeOn = not na(adaptWidthRatio) and adaptWidthRatio < adaptRatioLevel
adaptStatus = squeezeOn ? (close < adaptDonMid ? STATUS_LOW : close > adaptDonMid ? STATUS_UP : STATUS_MID) : STATUS_MID
adaptText = squeezeOn ? (close < adaptDonMid ? "PULLBACK LOW" : close > adaptDonMid ? "PULLBACK UP" : "PULLBACK MID") : "NO SQUEEZE"

// Summary and final signal.
maPoint = f_score(maStatus)
stoPoint = f_score(stoStatus)
sarPoint = f_score(sarStatus)
sdPoint = f_score(sdStatus)
envPoint = f_score(envStatus)
macdPoint = f_score(macdStatus)
rsiPoint = f_score(rsiStatus)
cciPoint = f_score(cciStatus)
donPoint = f_score(donStatus)
regimePoint = f_score(regimeStatus)
vpiPoint = f_score(vpiStatus)
mtfPoint = f_score(mtfStatus)
sweepPoint = f_score(sweepStatus)
adaptPoint = f_score(adaptStatus)

usedCount = 14
totalScore = maPoint + stoPoint + sarPoint + sdPoint + envPoint + macdPoint + rsiPoint + cciPoint + donPoint + regimePoint + vpiPoint + mtfPoint + sweepPoint + adaptPoint
scoreNorm = totalScore / usedCount

upCount = f_upCount(maStatus) + f_upCount(stoStatus) + f_upCount(sarStatus) + f_upCount(sdStatus) + f_upCount(envStatus) + f_upCount(macdStatus) + f_upCount(rsiStatus) + f_upCount(cciStatus) + f_upCount(donStatus) + f_upCount(regimeStatus) + f_upCount(vpiStatus) + f_upCount(mtfStatus) + f_upCount(sweepStatus) + f_upCount(adaptStatus)
lowCount = f_lowCount(maStatus) + f_lowCount(stoStatus) + f_lowCount(sarStatus) + f_lowCount(sdStatus) + f_lowCount(envStatus) + f_lowCount(macdStatus) + f_lowCount(rsiStatus) + f_lowCount(cciStatus) + f_lowCount(donStatus) + f_lowCount(regimeStatus) + f_lowCount(vpiStatus) + f_lowCount(mtfStatus) + f_lowCount(sweepStatus) + f_lowCount(adaptStatus)

summaryStatus = scoreNorm >= summaryUpLevel ? STATUS_UP : scoreNorm <= summaryLowLevel ? STATUS_LOW : math.abs(scoreNorm) <= summaryRangeLevel and regimeStatus == STATUS_RANGE ? STATUS_RANGE : STATUS_MID
tieBuy = not na(ema50) and not na(donMid) ? close >= ema50 and close >= donMid : not na(ema50) ? close >= ema50 : not na(donMid) ? close >= donMid : close >= nz(close[1], close)
finalSignal = scoreNorm >= signalBiasLevel ? SIGNAL_BUY : scoreNorm <= -signalBiasLevel ? SIGNAL_SELL : summaryStatus == STATUS_UP ? SIGNAL_BUY : summaryStatus == STATUS_LOW ? SIGNAL_SELL : tieBuy ? SIGNAL_BUY : SIGNAL_SELL
finalBuyBias = finalSignal == SIGNAL_BUY
finalSellBias = finalSignal == SIGNAL_SELL

// Asymmetric bias filters. HTF and macro series use confirmed-bar request.security() calls.
biasHtfClose = request.security(syminfo.tickerid, biasHtfTf, close[1], lookahead = barmerge.lookahead_on)
biasHtfEma = request.security(syminfo.tickerid, biasHtfTf, ta.ema(close, maLen)[1], lookahead = barmerge.lookahead_on)
biasHtfBullish = not na(biasHtfClose) and not na(biasHtfEma) and biasHtfClose > biasHtfEma
biasHtfBearish = not na(biasHtfClose) and not na(biasHtfEma) and biasHtfClose < biasHtfEma

dxyClose = request.security(dxySymbol, macroTf, close[1], lookahead = barmerge.lookahead_on)
dxyEma = request.security(dxySymbol, macroTf, ta.ema(close, maLen)[1], lookahead = barmerge.lookahead_on)
dxyRoc = request.security(dxySymbol, macroTf, ta.roc(close, 5)[1], lookahead = barmerge.lookahead_on)
dxyBullishForGold = not na(dxyClose) and not na(dxyEma) and not na(dxyRoc) and (dxyClose > dxyEma or dxyRoc > 0.0)
dxyBearishForGold = not na(dxyClose) and not na(dxyEma) and not na(dxyRoc) and (dxyClose < dxyEma or dxyRoc < 0.0)

us10yClose = request.security(us10ySymbol, macroTf, close[1], lookahead = barmerge.lookahead_on)
us10yEma = request.security(us10ySymbol, macroTf, ta.ema(close, maLen)[1], lookahead = barmerge.lookahead_on)
us10yRoc = request.security(us10ySymbol, macroTf, ta.roc(close, 5)[1], lookahead = barmerge.lookahead_on)
us10yBullishForGold = not na(us10yClose) and not na(us10yEma) and not na(us10yRoc) and (us10yClose > us10yEma or us10yRoc > 0.0)
us10yBearishForGold = not na(us10yClose) and not na(us10yEma) and not na(us10yRoc) and (us10yClose < us10yEma or us10yRoc < 0.0)

longBiasScore = (biasUseFinalSignal and finalBuyBias ? 2 : 0) + (biasUseHtfTrend and biasHtfBullish ? 1 : 0) + (biasUseDxy and dxyBearishForGold ? 1 : 0) + (biasUseUs10y and us10yBearishForGold ? 1 : 0)
shortBiasScore = (biasUseFinalSignal and finalSellBias ? 2 : 0) + (biasUseHtfTrend and biasHtfBearish ? 1 : 0) + (biasUseDxy and dxyBullishForGold ? 1 : 0) + (biasUseUs10y and us10yBullishForGold ? 1 : 0)
allowLongMeanRev = not enableAsymBias or longBiasScore >= longBiasMinScore
allowShortMeanRev = not enableAsymBias or shortBiasScore >= shortBiasMinScore

// Tactical support/resistance touch logic uses the currently enabled visual bands.
sdLowerActive = showSD ? sdLower : na
envLowerActive = showENV ? envLower : na
donLowerActive = showDON ? donLower : na
sdUpperActive = showSD ? sdUpper : na
envUpperActive = showENV ? envUpper : na
donUpperActive = showDON ? donUpper : na

activeLower = f_minNotNa(f_minNotNa(sdLowerActive, envLowerActive), donLowerActive)
activeUpper = f_maxNotNa(f_maxNotNa(sdUpperActive, envUpperActive), donUpperActive)

hitLower = not na(activeLower) and low <= activeLower
hitUpper = not na(activeUpper) and high >= activeUpper
bullConfirm = not na(activeLower) and close > open and close > activeLower
bearConfirm = not na(activeUpper) and close < open and close < activeUpper
rawTacticalLong = hitLower and bullConfirm
rawTacticalShort = hitUpper and bearConfirm
tacticalConflict = rawTacticalLong and rawTacticalShort
tacticalLong = rawTacticalLong and not tacticalConflict
tacticalShort = rawTacticalShort and not tacticalConflict

// Dynamic Grid Range Engine: mean-reversion SD zones around a selectable middle line.
sessionVwap = ta.vwap(hlc3)
gridMid = gridSource == GRID_SRC_DON ? donMid : gridSource == GRID_SRC_SD ? sdBasis : gridSource == GRID_SRC_EMA ? ema50 : not na(sessionVwap) ? sessionVwap : donMid
gridDev = ta.stdev(close, gridSdLen)
gridReady = not na(gridMid) and not na(gridDev) and gridDev > 0.0
upperNoTrade = gridReady ? gridMid + gridDev * noTradeSd : na
lowerNoTrade = gridReady ? gridMid - gridDev * noTradeSd : na
upperEntry = gridReady ? gridMid + gridDev * entrySd : na
lowerEntry = gridReady ? gridMid - gridDev * entrySd : na
upperStop = gridReady ? gridMid + gridDev * stopSd : na
lowerStop = gridReady ? gridMid - gridDev * stopSd : na
sigmaPos = gridReady ? (close - gridMid) / gridDev : 0.0

gridInNoTrade = gridReady and close >= lowerNoTrade and close <= upperNoTrade
gridLowerBreak = gridReady and close < lowerStop
gridUpperBreak = gridReady and close > upperStop
gridLowerBreakEvent = gridLowerBreak and not gridLowerBreak[1]
gridUpperBreakEvent = gridUpperBreak and not gridUpperBreak[1]
gridLowerReached = gridReady and (low <= lowerEntry or close <= lowerEntry)
gridUpperReached = gridReady and (high >= upperEntry or close >= upperEntry)
gridLongReject = gridReady and ((low <= lowerEntry and close > lowerEntry) or (useSweepConfirmation and lowTrap))
gridShortReject = gridReady and ((high >= upperEntry and close < upperEntry) or (useSweepConfirmation and highTrap))
gridTrendOk = not useTrendFilter or na(adxValue) or adxValue <= maxAdxForMeanReversion
gridRegime = not gridReady ? "n/a" : gridLowerBreak ? "LOWER BREAK" : gridUpperBreak ? "UPPER BREAK" : close <= lowerEntry ? "LOWER ENTRY" : close >= upperEntry ? "UPPER ENTRY" : "MIDDLE"

// Three-level SD ladder prices and basket exit rails.
ladderOrderMode = enableGridEngine and enableLadderGrid
longPx1 = gridReady ? gridMid - ladderSd1 * gridDev : na
longPx2 = gridReady ? gridMid - ladderSd2 * gridDev : na
longPx3 = gridReady ? gridMid - ladderSd3 * gridDev : na
shortPx1 = gridReady ? gridMid + ladderSd1 * gridDev : na
shortPx2 = gridReady ? gridMid + ladderSd2 * gridDev : na
shortPx3 = gridReady ? gridMid + ladderSd3 * gridDev : na

longTargetPx = gridReady ? gridMid + targetOffsetSd * gridDev : na
shortTargetPx = gridReady ? gridMid - targetOffsetSd * gridDev : na
longPartialCutPx = gridReady ? gridMid - partialCutSd * gridDev : na
shortPartialCutPx = gridReady ? gridMid + partialCutSd * gridDev : na
longSoftStopPx = gridReady ? gridMid - softStopSd * gridDev : na
shortSoftStopPx = gridReady ? gridMid + softStopSd * gridDev : na
longEmergencyStopPx = gridReady ? gridMid - emergencyStopSd * gridDev : na
shortEmergencyStopPx = gridReady ? gridMid + emergencyStopSd * gridDev : na

ladderTrendOk = not ladderUseTrendFilter or na(adxValue) or adxValue <= ladderMaxAdx
ladderLongRejectOk = not ladderUseSweepConfirmation or lowTrap or close > open
ladderShortRejectOk = not ladderUseSweepConfirmation or highTrap or close < open

// Read open rung state from TradingView's open-trade ledger.
gl1Open = f_hasOpenEntry(ID_GL1)
gl2Open = f_hasOpenEntry(ID_GL2)
gl3Open = f_hasOpenEntry(ID_GL3)
gs1Open = f_hasOpenEntry(ID_GS1)
gs2Open = f_hasOpenEntry(ID_GS2)
gs3Open = f_hasOpenEntry(ID_GS3)
ladderLongOpen = gl1Open or gl2Open or gl3Open
ladderShortOpen = gs1Open or gs2Open or gs3Open
ladderAnyOpen = ladderLongOpen or ladderShortOpen
ladderLongFilledCount = (gl1Open ? 1 : 0) + (gl2Open ? 1 : 0) + (gl3Open ? 1 : 0)
ladderShortFilledCount = (gs1Open ? 1 : 0) + (gs2Open ? 1 : 0) + (gs3Open ? 1 : 0)
ladderActiveSide = ladderLongOpen and ladderShortOpen ? "MIXED" : ladderLongOpen ? "LONG" : ladderShortOpen ? "SHORT" : "FLAT"

// Warmup, signal gating, and cooldown.
minBarsA = math.max(maLen, stoLen + stoSmoothK + stoSmoothD)
minBarsB = math.max(sdLen, math.max(envLen, donLen))
minBarsC = math.max(macdSlowLen + macdSignalLen, math.max(rsiLen, cciLen))
minBarsD = math.max(math.max(regimeDiLen + regimeAdxSmooth, regimeAtrLen + atrBaseLen), vpiLen + vpiSmooth)
minBarsE = math.max(sweepLookback, math.max(adaptSqueezeLen * 2, math.max(adaptDonLen, gridSdLen)))
minBarsNeeded = math.max(math.max(minBarsA, minBarsB), math.max(math.max(minBarsC, minBarsD), minBarsE)) + 2
enoughBars = bar_index >= minBarsNeeded

signalReady = enoughBars and (not confirmedOnly or barstate.isconfirmed)
ladderSignalReady = enoughBars and barstate.isconfirmed
tacticalLongSignal = signalReady and tacticalLong
tacticalShortSignal = signalReady and tacticalShort
longEntry = not enableGridEngine and tacticalLongSignal and (not requireBiasFilter or finalBuyBias)
shortEntry = not enableGridEngine and tacticalShortSignal and (not requireBiasFilter or finalSellBias)

var int lastTradeBar = na
closedTradeNow = strategy.closedtrades > nz(strategy.closedtrades[1])
if closedTradeNow
    lastTradeBar := bar_index
cooldownOk = na(lastTradeBar) or bar_index - lastTradeBar >= minBarsBetweenTrades

var bool ladderWasOpen = false
var int ladderLastBasketClosedBar = na
ladderBasketClosedNow = ladderWasOpen and not ladderAnyOpen
if ladderBasketClosedNow
    ladderLastBasketClosedBar := bar_index
ladderCooldownOk = na(ladderLastBasketClosedBar) or bar_index - ladderLastBasketClosedBar >= minBarsBetweenTrades
ladderCanStartOrAdd = ladderAnyOpen or ladderCooldownOk

// Legacy grid entries remain available when the ladder grid is disabled.
gridSignalReady = enableGridEngine and not enableLadderGrid and signalReady and gridReady
gridLongRaw = gridSignalReady and not gridInNoTrade and gridLowerReached and gridLongReject and gridTrendOk and not gridLowerBreak
gridShortRaw = gridSignalReady and not gridInNoTrade and gridUpperReached and gridShortReject and gridTrendOk and not gridUpperBreak
gridSignalConflict = gridLongRaw and gridShortRaw
gridLongSignal = gridLongRaw and not gridSignalConflict
gridShortSignal = gridShortRaw and not gridSignalConflict

gridLongMiddleExit = enableGridEngine and not enableLadderGrid and signalReady and strategy.position_size > 0 and gridReady and (closeAtMiddleMode == CLOSE_CROSS ? close >= gridMid : high >= gridMid)
gridShortMiddleExit = enableGridEngine and not enableLadderGrid and signalReady and strategy.position_size < 0 and gridReady and (closeAtMiddleMode == CLOSE_CROSS ? close <= gridMid : low <= gridMid)
gridMiddleExitSignal = gridLongMiddleExit or gridShortMiddleExit

// Base order quantity remains explicit for every entry path.
orderQty = f_orderQty(sizeMode, fixedQty, equityPct)
validQty = not na(orderQty) and orderQty > 0.0
gridFlatOk = not useOneTradeOnly or strategy.position_size == 0
gridCanOpen = executeOrders and enableGridEngine and not enableLadderGrid and validQty and cooldownOk and not gridMiddleExitSignal and gridFlatOk

gridLongHardStop = strategy.position_size > 0 and gridReady ? (fixedGoldStopCapPoints > 0.0 ? math.max(lowerStop, strategy.position_avg_price - fixedGoldStopCapPoints) : lowerStop) : na
gridShortHardStop = strategy.position_size < 0 and gridReady ? (fixedGoldStopCapPoints > 0.0 ? math.min(upperStop, strategy.position_avg_price + fixedGoldStopCapPoints) : upperStop) : na
gridNominalStopDistance = gridReady ? gridDev * math.max(stopSd - entrySd, 0.0) : na
gridStopDistancePoints = strategy.position_size > 0 and not na(gridLongHardStop) ? math.abs(strategy.position_avg_price - gridLongHardStop) : strategy.position_size < 0 and not na(gridShortHardStop) ? math.abs(gridShortHardStop - strategy.position_avg_price) : gridNominalStopDistance

// Weighted basket risk sizing for long and short ladders.
pointValue = syminfo.pointvalue
basketRiskDollar = strategy.equity * basketRiskPct * 0.01
minRiskUnit = syminfo.mintick * pointValue

longRisk1 = gridReady ? math.max((longPx1 - longEmergencyStopPx) * pointValue, minRiskUnit) : na
longRisk2 = gridReady ? math.max((longPx2 - longEmergencyStopPx) * pointValue, minRiskUnit) : na
longRisk3 = gridReady ? math.max((longPx3 - longEmergencyStopPx) * pointValue, minRiskUnit) : na
shortRisk1 = gridReady ? math.max((shortEmergencyStopPx - shortPx1) * pointValue, minRiskUnit) : na
shortRisk2 = gridReady ? math.max((shortEmergencyStopPx - shortPx2) * pointValue, minRiskUnit) : na
shortRisk3 = gridReady ? math.max((shortEmergencyStopPx - shortPx3) * pointValue, minRiskUnit) : na

weightedLongRiskDen = gridReady ? ladderWeight1 * longRisk1 + ladderWeight2 * longRisk2 + ladderWeight3 * longRisk3 : na
weightedShortRiskDen = gridReady ? ladderWeight1 * shortRisk1 + ladderWeight2 * shortRisk2 + ladderWeight3 * shortRisk3 : na
longBaseQty = useBasketRiskSizing and not na(weightedLongRiskDen) and weightedLongRiskDen > 0.0 ? basketRiskDollar / weightedLongRiskDen : orderQty
shortBaseQty = useBasketRiskSizing and not na(weightedShortRiskDen) and weightedShortRiskDen > 0.0 ? basketRiskDollar / weightedShortRiskDen : orderQty

rawLongQty1 = longBaseQty * ladderWeight1 * longBiasSizeMult
rawLongQty2 = longBaseQty * ladderWeight2 * longBiasSizeMult
rawLongQty3 = longBaseQty * ladderWeight3 * longBiasSizeMult
rawShortQty1 = shortBaseQty * ladderWeight1 * shortBiasSizeMult
rawShortQty2 = shortBaseQty * ladderWeight2 * shortBiasSizeMult
rawShortQty3 = shortBaseQty * ladderWeight3 * shortBiasSizeMult

maxNotionalDollar = strategy.equity * maxNotionalPct * 0.01
longNotionalDollar = gridReady ? (rawLongQty1 * longPx1 + rawLongQty2 * longPx2 + rawLongQty3 * longPx3) * pointValue : na
shortNotionalDollar = gridReady ? (rawShortQty1 * shortPx1 + rawShortQty2 * shortPx2 + rawShortQty3 * shortPx3) * pointValue : na
longNotionalScale = not na(longNotionalDollar) and maxNotionalDollar > 0.0 and longNotionalDollar > maxNotionalDollar ? maxNotionalDollar / longNotionalDollar : 1.0
shortNotionalScale = not na(shortNotionalDollar) and maxNotionalDollar > 0.0 and shortNotionalDollar > maxNotionalDollar ? maxNotionalDollar / shortNotionalDollar : 1.0

ladderLongQty1 = math.max(rawLongQty1 * longNotionalScale, 0.0)
ladderLongQty2 = math.max(rawLongQty2 * longNotionalScale, 0.0)
ladderLongQty3 = math.max(rawLongQty3 * longNotionalScale, 0.0)
ladderShortQty1 = math.max(rawShortQty1 * shortNotionalScale, 0.0)
ladderShortQty2 = math.max(rawShortQty2 * shortNotionalScale, 0.0)
ladderShortQty3 = math.max(rawShortQty3 * shortNotionalScale, 0.0)
ladderValidLongQty = ladderLongQty1 > 0.0 and ladderLongQty2 > 0.0 and ladderLongQty3 > 0.0
ladderValidShortQty = ladderShortQty1 > 0.0 and ladderShortQty2 > 0.0 and ladderShortQty3 > 0.0

// Fee-aware trade filters are evaluated per candidate rung.
entryIsLimit = entryMode == LADDER_LIMIT
exitIsLimit = false

longL1ProjectedRewardDollar = gridReady ? math.max(longTargetPx - longPx1, 0.0) * ladderLongQty1 * pointValue : na
longL2ProjectedRewardDollar = gridReady ? math.max(longTargetPx - longPx2, 0.0) * ladderLongQty2 * pointValue : na
longL3ProjectedRewardDollar = gridReady ? math.max(longTargetPx - longPx3, 0.0) * ladderLongQty3 * pointValue : na
shortL1ProjectedRewardDollar = gridReady ? math.max(shortPx1 - shortTargetPx, 0.0) * ladderShortQty1 * pointValue : na
shortL2ProjectedRewardDollar = gridReady ? math.max(shortPx2 - shortTargetPx, 0.0) * ladderShortQty2 * pointValue : na
shortL3ProjectedRewardDollar = gridReady ? math.max(shortPx3 - shortTargetPx, 0.0) * ladderShortQty3 * pointValue : na

longL1ProjectedRiskDollar = gridReady ? math.max(longPx1 - longEmergencyStopPx, 0.0) * ladderLongQty1 * pointValue : na
longL2ProjectedRiskDollar = gridReady ? math.max(longPx2 - longEmergencyStopPx, 0.0) * ladderLongQty2 * pointValue : na
longL3ProjectedRiskDollar = gridReady ? math.max(longPx3 - longEmergencyStopPx, 0.0) * ladderLongQty3 * pointValue : na
shortL1ProjectedRiskDollar = gridReady ? math.max(shortEmergencyStopPx - shortPx1, 0.0) * ladderShortQty1 * pointValue : na
shortL2ProjectedRiskDollar = gridReady ? math.max(shortEmergencyStopPx - shortPx2, 0.0) * ladderShortQty2 * pointValue : na
shortL3ProjectedRiskDollar = gridReady ? math.max(shortEmergencyStopPx - shortPx3, 0.0) * ladderShortQty3 * pointValue : na

longL1ProjectedCostDollar = gridReady ? f_roundTripCostDollar(longPx1, longTargetPx, ladderLongQty1, entryIsLimit, exitIsLimit) : na
longL2ProjectedCostDollar = gridReady ? f_roundTripCostDollar(longPx2, longTargetPx, ladderLongQty2, entryIsLimit, exitIsLimit) : na
longL3ProjectedCostDollar = gridReady ? f_roundTripCostDollar(longPx3, longTargetPx, ladderLongQty3, entryIsLimit, exitIsLimit) : na
shortL1ProjectedCostDollar = gridReady ? f_roundTripCostDollar(shortPx1, shortTargetPx, ladderShortQty1, entryIsLimit, exitIsLimit) : na
shortL2ProjectedCostDollar = gridReady ? f_roundTripCostDollar(shortPx2, shortTargetPx, ladderShortQty2, entryIsLimit, exitIsLimit) : na
shortL3ProjectedCostDollar = gridReady ? f_roundTripCostDollar(shortPx3, shortTargetPx, ladderShortQty3, entryIsLimit, exitIsLimit) : na

longL1RewardCostOk = f_rewardCostOk(longL1ProjectedRewardDollar, longL1ProjectedCostDollar)
longL2RewardCostOk = f_rewardCostOk(longL2ProjectedRewardDollar, longL2ProjectedCostDollar)
longL3RewardCostOk = f_rewardCostOk(longL3ProjectedRewardDollar, longL3ProjectedCostDollar)
shortL1RewardCostOk = f_rewardCostOk(shortL1ProjectedRewardDollar, shortL1ProjectedCostDollar)
shortL2RewardCostOk = f_rewardCostOk(shortL2ProjectedRewardDollar, shortL2ProjectedCostDollar)
shortL3RewardCostOk = f_rewardCostOk(shortL3ProjectedRewardDollar, shortL3ProjectedCostDollar)

longL1RewardRiskOk = f_rewardRiskOk(longL1ProjectedRewardDollar, longL1ProjectedRiskDollar)
longL2RewardRiskOk = f_rewardRiskOk(longL2ProjectedRewardDollar, longL2ProjectedRiskDollar)
longL3RewardRiskOk = f_rewardRiskOk(longL3ProjectedRewardDollar, longL3ProjectedRiskDollar)
shortL1RewardRiskOk = f_rewardRiskOk(shortL1ProjectedRewardDollar, shortL1ProjectedRiskDollar)
shortL2RewardRiskOk = f_rewardRiskOk(shortL2ProjectedRewardDollar, shortL2ProjectedRiskDollar)
shortL3RewardRiskOk = f_rewardRiskOk(shortL3ProjectedRewardDollar, shortL3ProjectedRiskDollar)

longL1FeeOk = longL1RewardCostOk and longL1RewardRiskOk
longL2FeeOk = longL2RewardCostOk and longL2RewardRiskOk
longL3FeeOk = longL3RewardCostOk and longL3RewardRiskOk
shortL1FeeOk = shortL1RewardCostOk and shortL1RewardRiskOk
shortL2FeeOk = shortL2RewardCostOk and shortL2RewardRiskOk
shortL3FeeOk = shortL3RewardCostOk and shortL3RewardRiskOk

// Ladder side gates prevent accidental auto-reversal.
ladderCanTrade = executeOrders and ladderOrderMode and ladderSignalReady and gridReady and validQty and ladderCanStartOrAdd and ladderTrendOk
ladderLongSideOk = ladderCanTrade and ladderAllowLongs and allowLongMeanRev and ladderValidLongQty and not ladderShortOpen and strategy.position_size >= 0
ladderShortSideOk = ladderCanTrade and ladderAllowShorts and allowShortMeanRev and ladderValidShortQty and not ladderLongOpen and strategy.position_size <= 0

longCapacityAvailable = ladderLongFilledCount < 3
shortCapacityAvailable = ladderShortFilledCount < 3
longReached1 = gridReady and low <= longPx1
longReached2 = gridReady and low <= longPx2
longReached3 = gridReady and low <= longPx3
shortReached1 = gridReady and high >= shortPx1
shortReached2 = gridReady and high >= shortPx2
shortReached3 = gridReady and high >= shortPx3

longReject1 = longReached1 and close > longPx1 and ladderLongRejectOk
longReject2 = longReached2 and close > longPx2 and ladderLongRejectOk and (gl1Open or longReached2)
longReject3 = longReached3 and close > longPx3 and ladderLongRejectOk and (gl2Open or longReached3)
shortReject1 = shortReached1 and close < shortPx1 and ladderShortRejectOk
shortReject2 = shortReached2 and close < shortPx2 and ladderShortRejectOk and (gs1Open or shortReached2)
shortReject3 = shortReached3 and close < shortPx3 and ladderShortRejectOk and (gs2Open or shortReached3)

ladderLongL1Signal = ladderLongSideOk and entryMode == LADDER_REJECT and not gl1Open and longCapacityAvailable and longReject1 and longL1FeeOk
ladderLongL2Signal = ladderLongSideOk and entryMode == LADDER_REJECT and not gl2Open and longCapacityAvailable and longReject2 and longL2FeeOk
ladderLongL3Signal = ladderLongSideOk and entryMode == LADDER_REJECT and not gl3Open and longCapacityAvailable and longReject3 and longL3FeeOk
ladderShortS1Signal = ladderShortSideOk and entryMode == LADDER_REJECT and not gs1Open and shortCapacityAvailable and shortReject1 and shortL1FeeOk
ladderShortS2Signal = ladderShortSideOk and entryMode == LADDER_REJECT and not gs2Open and shortCapacityAvailable and shortReject2 and shortL2FeeOk
ladderShortS3Signal = ladderShortSideOk and entryMode == LADDER_REJECT and not gs3Open and shortCapacityAvailable and shortReject3 and shortL3FeeOk

ladderLongRejectAny = ladderLongL1Signal or ladderLongL2Signal or ladderLongL3Signal
ladderShortRejectAny = ladderShortS1Signal or ladderShortS2Signal or ladderShortS3Signal
ladderRejectConflict = ladderLongRejectAny and ladderShortRejectAny

limitLongArm = ladderLongSideOk and entryMode == LADDER_LIMIT and allowLongMeanRev and (not allowShortMeanRev or longBiasScore >= shortBiasScore)
limitShortArm = ladderShortSideOk and entryMode == LADDER_LIMIT and allowShortMeanRev and not limitLongArm

// Basket exit conditions.
ladderLongTargetExit = ladderOrderMode and ladderSignalReady and ladderLongOpen and gridReady and high >= longTargetPx
ladderShortTargetExit = ladderOrderMode and ladderSignalReady and ladderShortOpen and gridReady and low <= shortTargetPx
ladderMidTargetExit = ladderLongTargetExit or ladderShortTargetExit

var int longStopCloseCount = 0
var int shortStopCloseCount = 0
longStopCloseCount := ladderOrderMode and ladderSignalReady and ladderLongOpen and gridReady and close <= longSoftStopPx ? longStopCloseCount + 1 : 0
shortStopCloseCount := ladderOrderMode and ladderSignalReady and ladderShortOpen and gridReady and close >= shortSoftStopPx ? shortStopCloseCount + 1 : 0
ladderLongSoftStopSignal = ladderOrderMode and ladderSignalReady and ladderLongOpen and longStopCloseCount >= stopConfirmBars
ladderShortSoftStopSignal = ladderOrderMode and ladderSignalReady and ladderShortOpen and shortStopCloseCount >= stopConfirmBars
ladderSoftStopSignal = ladderLongSoftStopSignal or ladderShortSoftStopSignal

var int basketEntryBar = na
if strategy.position_size != 0 and nz(strategy.position_size[1]) == 0
    basketEntryBar := bar_index
if strategy.position_size == 0
    basketEntryBar := na
staleTradeExit = ladderOrderMode and maxBarsInTrade > 0 and ladderAnyOpen and not na(basketEntryBar) and bar_index - basketEntryBar >= maxBarsInTrade

ladderLongEmergencyTouch = ladderOrderMode and ladderLongOpen and gridReady and low <= longEmergencyStopPx
ladderShortEmergencyTouch = ladderOrderMode and ladderShortOpen and gridReady and high >= shortEmergencyStopPx
ladderEmergencyStopTouch = ladderLongEmergencyTouch or ladderShortEmergencyTouch

// Flip logic uses explicit flat-then-open behavior.
var int pendingFlipDir = 0
shortFlipValid = ladderOrderMode and ladderSignalReady and ladderLongOpen and (shortReached1 or (flipOnZoneBreak and gridUpperBreak)) and (not flipRequiresBias or allowShortMeanRev)
longFlipValid = ladderOrderMode and ladderSignalReady and ladderShortOpen and (longReached1 or (flipOnZoneBreak and gridLowerBreak)) and (not flipRequiresBias or allowLongMeanRev)

bool didTradeAction = false
bool didGridFlip = false
bool didLadderBasketClose = false
bool gridLongL1Event = false
bool gridLongL2Event = false
bool gridLongL3Event = false
bool gridShortL1Event = false
bool gridShortL2Event = false
bool gridShortL3Event = false
bool gridPartialCutAlert = false
bool gridMidTargetExitAlert = false
bool gridSoftStopAlert = false
bool gridEmergencyStopAlert = ladderEmergencyStopTouch
bool gridFlipArmedAlert = false

// Ladder basket management, exits, limit placement, rejection entries, and flips.
if executeOrders and ladderOrderMode
    if ladderCancelOppositeOrders
        if ladderLongOpen
            f_cancelShortBasket()
        if ladderShortOpen
            f_cancelLongBasket()
        if limitLongArm
            f_cancelShortBasket()
        if limitShortArm
            f_cancelLongBasket()

    if shortFlipValid
        f_closeLongBasket("GRID FLIP CLOSE")
        f_cancelLongBasket()
        didLadderBasketClose := true
        gridFlipArmedAlert := true
        if allowSameBarFlip and ladderShortSideOk and shortL1FeeOk
            strategy.entry(ID_GS1, strategy.short, qty = ladderShortQty1, comment = "GRID FLIP S1")
            gridShortL1Event := true
            didTradeAction := true
        else
            pendingFlipDir := -1

    if longFlipValid
        f_closeShortBasket("GRID FLIP CLOSE")
        f_cancelShortBasket()
        didLadderBasketClose := true
        gridFlipArmedAlert := true
        if allowSameBarFlip and ladderLongSideOk and longL1FeeOk
            strategy.entry(ID_GL1, strategy.long, qty = ladderLongQty1, comment = "GRID FLIP L1")
            gridLongL1Event := true
            didTradeAction := true
        else
            pendingFlipDir := 1

    if pendingFlipDir == -1 and strategy.position_size == 0 and not ladderLongOpen and ladderShortSideOk and shortReached1 and shortL1FeeOk
        strategy.entry(ID_GS1, strategy.short, qty = ladderShortQty1, comment = "PENDING FLIP S1")
        gridShortL1Event := true
        didTradeAction := true
        pendingFlipDir := 0

    if pendingFlipDir == 1 and strategy.position_size == 0 and not ladderShortOpen and ladderLongSideOk and longReached1 and longL1FeeOk
        strategy.entry(ID_GL1, strategy.long, qty = ladderLongQty1, comment = "PENDING FLIP L1")
        gridLongL1Event := true
        didTradeAction := true
        pendingFlipDir := 0

    if ladderLongTargetExit
        f_closeLongBasket("GRID MID TARGET EXIT")
        f_cancelLongBasket()
        didLadderBasketClose := true
        gridMidTargetExitAlert := true

    if ladderShortTargetExit
        f_closeShortBasket("GRID MID TARGET EXIT")
        f_cancelShortBasket()
        didLadderBasketClose := true
        gridMidTargetExitAlert := true

    if ladderLongSoftStopSignal
        f_closeLongBasket("GRID SOFT STOP")
        f_cancelLongBasket()
        didLadderBasketClose := true
        gridSoftStopAlert := true

    if ladderShortSoftStopSignal
        f_closeShortBasket("GRID SOFT STOP")
        f_cancelShortBasket()
        didLadderBasketClose := true
        gridSoftStopAlert := true

    if staleTradeExit and ladderLongOpen
        f_closeLongBasket("GRID STALE EXIT")
        f_cancelLongBasket()
        didLadderBasketClose := true

    if staleTradeExit and ladderShortOpen
        f_closeShortBasket("GRID STALE EXIT")
        f_cancelShortBasket()
        didLadderBasketClose := true

    var int lastPartialCutBar = na
    partialCutGuardOk = na(lastPartialCutBar) or lastPartialCutBar != bar_index
    if partialCutGuardOk and ladderLongOpen and gridReady and close <= longPartialCutPx
        if gl3Open
            strategy.close(ID_GL3, comment = "GRID PARTIAL CUT")
            lastPartialCutBar := bar_index
            gridPartialCutAlert := true
        else if gl2Open
            strategy.close(ID_GL2, comment = "GRID PARTIAL CUT")
            lastPartialCutBar := bar_index
            gridPartialCutAlert := true

    if partialCutGuardOk and ladderShortOpen and gridReady and close >= shortPartialCutPx
        if gs3Open
            strategy.close(ID_GS3, comment = "GRID PARTIAL CUT")
            lastPartialCutBar := bar_index
            gridPartialCutAlert := true
        else if gs2Open
            strategy.close(ID_GS2, comment = "GRID PARTIAL CUT")
            lastPartialCutBar := bar_index
            gridPartialCutAlert := true

    if entryMode == LADDER_LIMIT and not ladderMidTargetExit and not ladderSoftStopSignal and not staleTradeExit and pendingFlipDir == 0
        if limitLongArm
            if not gl1Open and longL1FeeOk
                strategy.entry(ID_GL1, strategy.long, qty = ladderLongQty1, limit = longPx1, comment = "L1 2.0SD")
            if not gl2Open and longL2FeeOk
                strategy.entry(ID_GL2, strategy.long, qty = ladderLongQty2, limit = longPx2, comment = "L2 2.5SD")
            if not gl3Open and longL3FeeOk
                strategy.entry(ID_GL3, strategy.long, qty = ladderLongQty3, limit = longPx3, comment = "L3 3.0SD")
        if limitShortArm
            if not gs1Open and shortL1FeeOk
                strategy.entry(ID_GS1, strategy.short, qty = ladderShortQty1, limit = shortPx1, comment = "S1 2.0SD")
            if not gs2Open and shortL2FeeOk
                strategy.entry(ID_GS2, strategy.short, qty = ladderShortQty2, limit = shortPx2, comment = "S2 2.5SD")
            if not gs3Open and shortL3FeeOk
                strategy.entry(ID_GS3, strategy.short, qty = ladderShortQty3, limit = shortPx3, comment = "S3 3.0SD")

    if entryMode == LADDER_REJECT and not ladderRejectConflict and not ladderMidTargetExit and not ladderSoftStopSignal and not staleTradeExit and pendingFlipDir == 0
        if ladderLongL1Signal
            strategy.entry(ID_GL1, strategy.long, qty = ladderLongQty1, comment = "L1 2.0SD")
            gridLongL1Event := true
            didTradeAction := true
        if ladderLongL2Signal
            strategy.entry(ID_GL2, strategy.long, qty = ladderLongQty2, comment = "L2 2.5SD")
            gridLongL2Event := true
            didTradeAction := true
        if ladderLongL3Signal
            strategy.entry(ID_GL3, strategy.long, qty = ladderLongQty3, comment = "L3 3.0SD")
            gridLongL3Event := true
            didTradeAction := true
        if ladderShortS1Signal
            strategy.entry(ID_GS1, strategy.short, qty = ladderShortQty1, comment = "S1 2.0SD")
            gridShortL1Event := true
            didTradeAction := true
        if ladderShortS2Signal
            strategy.entry(ID_GS2, strategy.short, qty = ladderShortQty2, comment = "S2 2.5SD")
            gridShortL2Event := true
            didTradeAction := true
        if ladderShortS3Signal
            strategy.entry(ID_GS3, strategy.short, qty = ladderShortQty3, comment = "S3 3.0SD")
            gridShortL3Event := true
            didTradeAction := true

// Emergency stops are always tied to explicit from_entry IDs.
if gridReady and gl1Open
    strategy.exit("GX_GL_2_0_STOP", from_entry = ID_GL1, stop = longEmergencyStopPx)
if gridReady and gl2Open
    strategy.exit("GX_GL_2_5_STOP", from_entry = ID_GL2, stop = longEmergencyStopPx)
if gridReady and gl3Open
    strategy.exit("GX_GL_3_0_STOP", from_entry = ID_GL3, stop = longEmergencyStopPx)
if gridReady and gs1Open
    strategy.exit("GX_GS_2_0_STOP", from_entry = ID_GS1, stop = shortEmergencyStopPx)
if gridReady and gs2Open
    strategy.exit("GX_GS_2_5_STOP", from_entry = ID_GS2, stop = shortEmergencyStopPx)
if gridReady and gs3Open
    strategy.exit("GX_GS_3_0_STOP", from_entry = ID_GS3, stop = shortEmergencyStopPx)

if didLadderBasketClose
    ladderLastBasketClosedBar := bar_index

// Legacy grid and tactical order handling.
if executeOrders and enableGridEngine and not enableLadderGrid
    if gridLongMiddleExit
        strategy.close("Grid Long", comment = "MID EXIT")
        didTradeAction := true
    if gridShortMiddleExit
        strategy.close("Grid Short", comment = "MID EXIT")
        didTradeAction := true

if allowFlipOnZoneBreak and validQty and signalReady
    if strategy.position_size < 0 and gridUpperBreak
        strategy.close("Grid Short", comment = "ZONE BREAK")
        didTradeAction := true
        didGridFlip := true
        if cooldownOk and (not useOneTradeOnly or strategy.position_size == 0)
            strategy.entry("Grid Long", strategy.long, qty = orderQty, comment = "Grid Flip Long")
            didTradeAction := true
    else if strategy.position_size > 0 and gridLowerBreak
        strategy.close("Grid Long", comment = "ZONE BREAK")
        didTradeAction := true
        didGridFlip := true
        if cooldownOk and (not useOneTradeOnly or strategy.position_size == 0)
            strategy.entry("Grid Short", strategy.short, qty = orderQty, comment = "Grid Flip Short")
            didTradeAction := true

if gridCanOpen and not didGridFlip
    if gridLongSignal and not gridShortSignal
        strategy.entry("Grid Long", strategy.long, qty = orderQty, comment = "Grid Long")
        didTradeAction := true
    else if gridShortSignal and not gridLongSignal
        strategy.entry("Grid Short", strategy.short, qty = orderQty, comment = "Grid Short")
        didTradeAction := true

if executeOrders and enableGridEngine and not enableLadderGrid and strategy.position_size > 0 and not na(gridLongHardStop)
    strategy.exit("Grid Long Stop", from_entry = "Grid Long", stop = gridLongHardStop)

if executeOrders and enableGridEngine and not enableLadderGrid and strategy.position_size < 0 and not na(gridShortHardStop)
    strategy.exit("Grid Short Stop", from_entry = "Grid Short", stop = gridShortHardStop)

if executeOrders and not enableGridEngine and validQty
    if longEntry and not shortEntry
        strategy.entry("Long", strategy.long, qty = orderQty, comment = "Tactical Long")
        didTradeAction := true
    else if shortEntry and not longEntry
        strategy.entry("Short", strategy.short, qty = orderQty, comment = "Tactical Short")
        didTradeAction := true

exitAtr = ta.atr(exitAtrLen)

longStopRaw = exitMode == EXIT_DON ? donLower : exitMode == EXIT_ENV ? envLower : strategy.position_avg_price - exitAtr * atrStopMult
longLimitRaw = exitMode == EXIT_DON ? donUpper : exitMode == EXIT_ENV ? envUpper : strategy.position_avg_price + exitAtr * atrTargetMult
shortStopRaw = exitMode == EXIT_DON ? donUpper : exitMode == EXIT_ENV ? envUpper : strategy.position_avg_price + exitAtr * atrStopMult
shortLimitRaw = exitMode == EXIT_DON ? donLower : exitMode == EXIT_ENV ? envLower : strategy.position_avg_price - exitAtr * atrTargetMult

longStop = strategy.position_size > 0 and not na(longStopRaw) and longStopRaw < strategy.position_avg_price ? longStopRaw : na
longLimit = strategy.position_size > 0 and not na(longLimitRaw) and longLimitRaw > strategy.position_avg_price ? longLimitRaw : na
shortStop = strategy.position_size < 0 and not na(shortStopRaw) and shortStopRaw > strategy.position_avg_price ? shortStopRaw : na
shortLimit = strategy.position_size < 0 and not na(shortLimitRaw) and shortLimitRaw < strategy.position_avg_price ? shortLimitRaw : na

if executeOrders and not enableGridEngine and strategy.position_size > 0 and (not na(longStop) or not na(longLimit))
    strategy.exit("Long Exit", from_entry = "Long", stop = longStop, limit = longLimit)

if executeOrders and not enableGridEngine and strategy.position_size < 0 and (not na(shortStop) or not na(shortLimit))
    strategy.exit("Short Exit", from_entry = "Short", stop = shortStop, limit = shortLimit)

if didTradeAction
    lastTradeBar := bar_index
ladderWasOpen := didLadderBasketClose ? false : ladderAnyOpen

// Chart visuals.
plot(showMA ? ema50 : na, "EMA 50", color = color.new(color.yellow, 0), linewidth = 2)
plot(showSAR ? sarValue : na, "SAR", color = color.new(color.aqua, 0), style = plot.style_circles, linewidth = 2)

sdUpperPlot = plot(showSD ? sdUpper : na, "SD Upper", color = color.new(color.blue, 0))
sdBasisPlot = plot(showSD ? sdBasis : na, "SD Basis", color = color.new(color.blue, 55))
sdLowerPlot = plot(showSD ? sdLower : na, "SD Lower", color = color.new(color.blue, 0))
fill(sdUpperPlot, sdLowerPlot, color = color.new(color.blue, 90))

envUpperPlot = plot(showENV ? envUpper : na, "ENV Upper", color = color.new(color.purple, 0))
envBasisPlot = plot(showENV ? envBasis : na, "ENV Basis", color = color.new(color.purple, 55))
envLowerPlot = plot(showENV ? envLower : na, "ENV Lower", color = color.new(color.purple, 0))
fill(envUpperPlot, envLowerPlot, color = color.new(color.purple, 92))

donUpperPlot = plot(showDON ? donUpper : na, "DON Upper", color = color.new(color.orange, 0))
donMidPlot = plot(showDON ? donMid : na, "DON Middle", color = color.new(color.orange, 35))
donLowerPlot = plot(showDON ? donLower : na, "DON Lower", color = color.new(color.orange, 0))
fill(donUpperPlot, donLowerPlot, color = color.new(color.orange, 90))

gridMidPlot = plot(showGridLines ? gridMid : na, "Grid Mid", color = color.new(color.white, 0), linewidth = 2)
gridUpperEntryPlot = plot(showGridLines ? upperEntry : na, "Grid Upper Entry", color = color.new(color.red, 25), linewidth = 1)
gridLowerEntryPlot = plot(showGridLines ? lowerEntry : na, "Grid Lower Entry", color = color.new(color.lime, 25), linewidth = 1)
gridUpperStopPlot = plot(showGridLines ? upperStop : na, "Grid Upper Stop", color = color.new(color.red, 0), linewidth = 1)
gridLowerStopPlot = plot(showGridLines ? lowerStop : na, "Grid Lower Stop", color = color.new(color.lime, 0), linewidth = 1)

ladderShow = showGridLines and ladderOrderMode
ladderUpper1Plot = plot(ladderShow ? shortPx1 : na, "Ladder Upper 2.0SD", color = color.new(color.red, 75), linewidth = 1)
ladderLower1Plot = plot(ladderShow ? longPx1 : na, "Ladder Lower 2.0SD", color = color.new(color.lime, 75), linewidth = 1)
ladderUpper2Plot = plot(ladderShow ? shortPx2 : na, "Ladder Upper 2.5SD", color = color.new(color.red, 45), linewidth = 1)
ladderLower2Plot = plot(ladderShow ? longPx2 : na, "Ladder Lower 2.5SD", color = color.new(color.lime, 45), linewidth = 1)
ladderUpper3Plot = plot(ladderShow ? shortPx3 : na, "Ladder Upper 3.0SD", color = color.new(color.red, 10), linewidth = 2)
ladderLower3Plot = plot(ladderShow ? longPx3 : na, "Ladder Lower 3.0SD", color = color.new(color.lime, 10), linewidth = 2)
longTargetPlot = plot(ladderShow ? longTargetPx : na, "Grid Long Target", color = color.new(color.yellow, 0), linewidth = 2)
shortTargetPlot = plot(ladderShow ? shortTargetPx : na, "Grid Short Target", color = color.new(color.yellow, 0), linewidth = 2)
longSoftStopPlot = plot(ladderShow ? longSoftStopPx : na, "Grid Long Soft Stop", color = color.new(color.lime, 0), linewidth = 2)
shortSoftStopPlot = plot(ladderShow ? shortSoftStopPx : na, "Grid Short Soft Stop", color = color.new(color.red, 0), linewidth = 2)
longEmergencyStopPlot = plot(ladderShow ? longEmergencyStopPx : na, "Grid Long Emergency Stop", color = color.new(color.lime, 0), style = plot.style_circles, linewidth = 2)
shortEmergencyStopPlot = plot(ladderShow ? shortEmergencyStopPx : na, "Grid Short Emergency Stop", color = color.new(color.red, 0), style = plot.style_circles, linewidth = 2)

longOnlyBias = enableAsymBias and allowLongMeanRev and not allowShortMeanRev
shortOnlyBias = enableAsymBias and allowShortMeanRev and not allowLongMeanRev

// Markers.
gridVisualCanOpen = enableGridEngine and cooldownOk and not gridMiddleExitSignal and gridFlatOk
gridLongMarker = gridLongSignal and gridVisualCanOpen
gridShortMarker = gridShortSignal and gridVisualCanOpen
gridLowerBreakMarker = enableGridEngine and signalReady and gridLowerBreakEvent
gridUpperBreakMarker = enableGridEngine and signalReady and gridUpperBreakEvent
ladderLongL1Marker = gridLongL1Event or (gl1Open and not gl1Open[1])
ladderLongL2Marker = gridLongL2Event or (gl2Open and not gl2Open[1])
ladderLongL3Marker = gridLongL3Event or (gl3Open and not gl3Open[1])
ladderShortS1Marker = gridShortL1Event or (gs1Open and not gs1Open[1])
ladderShortS2Marker = gridShortL2Event or (gs2Open and not gs2Open[1])
ladderShortS3Marker = gridShortL3Event or (gs3Open and not gs3Open[1])
ladderMidExitMarker = gridMidTargetExitAlert
ladderLongStopMarker = gridSoftStopAlert or ladderLongEmergencyTouch
ladderShortStopMarker = gridSoftStopAlert or ladderShortEmergencyTouch
gridZoneBreakMarker = gridLowerBreakMarker or gridUpperBreakMarker
ladderLongAnyMarker = ladderLongL1Marker or ladderLongL2Marker or ladderLongL3Marker
ladderShortAnyMarker = ladderShortS1Marker or ladderShortS2Marker or ladderShortS3Marker
ladderStopMarker = ladderLongStopMarker or ladderShortStopMarker

plotshape(tacticalLongSignal, "Tactical Long", style = shape.triangleup, location = location.belowbar, color = color.new(color.lime, 0), text = "LONG", textcolor = color.white, size = size.tiny)
plotshape(tacticalShortSignal, "Tactical Short", style = shape.triangledown, location = location.abovebar, color = color.new(color.red, 0), text = "SHORT", textcolor = color.white, size = size.tiny)
plotshape(gridLongMarker, "Grid Long", style = shape.labelup, location = location.belowbar, color = color.new(color.teal, 0), text = "GRID LONG", textcolor = color.white, size = size.tiny)
plotshape(gridShortMarker, "Grid Short", style = shape.labeldown, location = location.abovebar, color = color.new(color.maroon, 0), text = "GRID SHORT", textcolor = color.white, size = size.tiny)
plotshape(gridMiddleExitSignal ? gridMid : na, "Grid Mid Exit", style = shape.circle, location = location.absolute, color = color.new(color.white, 0), text = "MID EXIT", textcolor = color.black, size = size.tiny)
plotshape(gridZoneBreakMarker ? close : na, "Grid Zone Break", style = shape.xcross, location = location.absolute, color = color.new(color.red, 0), text = "ZONE BREAK", textcolor = color.white, size = size.tiny)
plotshape(ladderLongAnyMarker, "Ladder Long Rung", style = shape.labelup, location = location.belowbar, color = color.new(color.lime, 25), text = "LADDER L", textcolor = color.white, size = size.tiny)
plotshape(ladderShortAnyMarker, "Ladder Short Rung", style = shape.labeldown, location = location.abovebar, color = color.new(color.red, 25), text = "LADDER S", textcolor = color.white, size = size.tiny)
plotshape(ladderMidExitMarker ? gridMid : na, "Ladder Mid Exit", style = shape.circle, location = location.absolute, color = color.new(color.yellow, 0), text = "LADDER MID EXIT", textcolor = color.black, size = size.tiny)
plotshape(ladderLongStopMarker ? low : ladderShortStopMarker ? high : na, "Ladder Stop", style = shape.xcross, location = location.absolute, color = color.new(color.red, 0), text = "LADDER STOP", textcolor = color.white, size = size.tiny)

// Alerts. Legacy alerts are preserved and new granular grid alerts are additive.
alertcondition(signalReady and finalBuyBias, "BUY BIAS", "BUY BIAS")
alertcondition(signalReady and finalSellBias, "SELL BIAS", "SELL BIAS")
alertcondition(tacticalLongSignal, "Tactical Long", "Tactical long: lower support hit with bullish confirmation.")
alertcondition(tacticalShortSignal, "Tactical Short", "Tactical short: upper resistance hit with bearish confirmation.")
alertcondition(gridLongMarker, "GRID LONG", "GRID LONG: lower dynamic SD zone rejection.")
alertcondition(gridShortMarker, "GRID SHORT", "GRID SHORT: upper dynamic SD zone rejection.")
alertcondition(gridMiddleExitSignal, "GRID MID EXIT", "GRID MID EXIT: price returned to the grid middle.")
alertcondition(gridLowerBreakMarker or gridUpperBreakMarker, "GRID ZONE BREAK", "GRID ZONE BREAK: price closed beyond the dynamic stop zone.")
alertcondition(ladderLongL1Marker or ladderLongL2Marker or ladderLongL3Marker, "LADDER LONG", "LADDER LONG: 3-level SD ladder long entry.")
alertcondition(ladderShortS1Marker or ladderShortS2Marker or ladderShortS3Marker, "LADDER SHORT", "LADDER SHORT: 3-level SD ladder short entry.")
alertcondition(ladderMidExitMarker, "LADDER MID EXIT", "LADDER MID EXIT: basket reached the grid target.")
alertcondition(ladderLongStopMarker or ladderShortStopMarker, "LADDER STOP", "LADDER STOP: ladder soft or emergency stop condition.")
alertcondition(ladderLongL1Marker, "GRID LONG L1", "GRID LONG L1: GL_2_0 rung fired or filled.")
alertcondition(ladderLongL2Marker, "GRID LONG L2", "GRID LONG L2: GL_2_5 rung fired or filled.")
alertcondition(ladderLongL3Marker, "GRID LONG L3", "GRID LONG L3: GL_3_0 rung fired or filled.")
alertcondition(ladderShortS1Marker, "GRID SHORT L1", "GRID SHORT L1: GS_2_0 rung fired or filled.")
alertcondition(ladderShortS2Marker, "GRID SHORT L2", "GRID SHORT L2: GS_2_5 rung fired or filled.")
alertcondition(ladderShortS3Marker, "GRID SHORT L3", "GRID SHORT L3: GS_3_0 rung fired or filled.")
alertcondition(gridPartialCutAlert, "GRID PARTIAL CUT", "GRID PARTIAL CUT: deepest open ladder rung was reduced.")
alertcondition(gridMidTargetExitAlert, "GRID MID TARGET EXIT", "GRID MID TARGET EXIT: basket reached the target rail.")
alertcondition(gridSoftStopAlert, "GRID SOFT STOP", "GRID SOFT STOP: confirmed close beyond soft stop.")
alertcondition(gridEmergencyStopAlert, "GRID EMERGENCY STOP", "GRID EMERGENCY STOP: price touched emergency stop rail.")
alertcondition(gridFlipArmedAlert, "GRID FLIP ARMED", "GRID FLIP ARMED: opposite ladder condition closed the active basket and armed a flip.")

// Internal performance panel.
var float peakEquity = na
peakEquity := na(peakEquity) ? strategy.equity : math.max(peakEquity, strategy.equity)
drawdownPctNow = peakEquity != 0.0 ? (strategy.equity - peakEquity) / peakEquity * 100.0 : 0.0

var float maxDrawdownPct = 0.0
maxDrawdownPct := math.min(maxDrawdownPct, drawdownPctNow)

netProfitPct = f_safeDiv(strategy.netprofit, 100000.0, 0.0) * 100.0
winRatePct = strategy.closedtrades > 0 ? strategy.wintrades * 100.0 / strategy.closedtrades : na

barsPerYearRaw = not na(chartSeconds) and chartSeconds > 0 ? 31557600.0 / chartSeconds : 252.0
barsPerYear = math.max(barsPerYearRaw, 1.0)
equityReturn = strategy.equity[1] > 0.0 ? strategy.equity / strategy.equity[1] - 1.0 : 0.0
riskFreePerBar = riskFreeRateInput * 0.01 / barsPerYear
excessReturn = equityReturn - riskFreePerBar
meanExcessReturn = ta.sma(excessReturn, customSharpeLen)
stdevExcessReturn = ta.stdev(excessReturn, customSharpeLen)
customSharpe = not na(stdevExcessReturn) and stdevExcessReturn != 0.0 ? meanExcessReturn / stdevExcessReturn * math.sqrt(barsPerYear) : na

// Dashboard table. The original 14-indicator rows are preserved; new ladder rows are additive.
var table dash = table.new(position.top_right, 3, 52, border_width = 1, border_color = color.new(color.gray, 55), frame_width = 1, frame_color = color.new(color.gray, 55))

if barstate.islast
    table.cell(dash, 0, 0, "IND", text_color = color.white, bgcolor = color.new(color.black, 0), text_halign = text.align_left, text_size = size.small)
    table.cell(dash, 1, 0, "STATUS", text_color = color.white, bgcolor = color.new(color.black, 0), text_halign = text.align_center, text_size = size.small)
    table.cell(dash, 2, 0, "VALUE", text_color = color.white, bgcolor = color.new(color.black, 0), text_halign = text.align_left, text_size = size.small)

    f_renderRow(dash, 1, "MA", maStatus, "EMA" + str.tostring(maLen) + " " + f_price(ema50))
    f_renderRow(dash, 2, "STO", stoStatus, "K " + f_num(stoK) + " / D " + f_num(stoD))
    f_renderRow(dash, 3, "SAR", sarStatus, "SAR " + f_price(sarValue))
    f_renderRow(dash, 4, "SD", sdStatus, "z " + f_num(sdZ) + " / SMA " + f_price(sdBasis))
    f_renderRow(dash, 5, "ENV", envStatus, "Basis " + f_price(envBasis))
    f_renderRow(dash, 6, "MACD", macdStatus, "Hist " + f_num(macdHist))
    f_renderRow(dash, 7, "RSI", rsiStatus, "RSI " + f_num(rsiValue))
    f_renderRow(dash, 8, "CCI", cciStatus, "CCI " + f_num(cciValue))
    f_renderRow(dash, 9, "DON", donStatus, "Mid " + f_price(donMid))
    f_renderRow(dash, 10, "REGIME", regimeStatus, "ADX " + f_num(adxValue) + " / ATRr " + f_num(atrRatio))
    f_renderRow(dash, 11, "VPI", vpiStatus, hasVolume ? "VPI " + f_num(vpi) : "NO VOLUME")
    f_renderRow(dash, 12, "MTF", mtfStatus, mtfTf + " Strong" + str.tostring(mtfStrongVotes) + " UP " + str.tostring(mtfUpVotes) + " / LOW " + str.tostring(mtfLowVotes))
    f_renderRow(dash, 13, "SWEEP", sweepStatus, sweepText)
    f_renderRow(dash, 14, "ADAPT", adaptStatus, adaptText + " / R " + f_num(adaptWidthRatio))
    f_renderRow(dash, 15, "SUMMARY", summaryStatus, "UP " + str.tostring(upCount) + " / LOW " + str.tostring(lowCount) + " / USE " + str.tostring(usedCount))
    f_renderRow(dash, 16, "SIGNAL", finalSignal, "Score " + f_num(scoreNorm) + " (" + str.tostring(totalScore) + "/" + str.tostring(usedCount) + ")")

    f_renderInfoRow(dash, 17, "GRID MODE", enableGridEngine ? "ON / " + gridSource : "OFF / Tactical")
    f_renderInfoRow(dash, 18, "GRID SIGMA", f_num(sigmaPos))
    f_renderInfoRow(dash, 19, "GRID REGIME", gridRegime)
    f_renderInfoRow(dash, 20, "GRID 1SD", f_price(gridDev))
    f_renderInfoRow(dash, 21, "GRID STOP", f_price(gridStopDistancePoints))

    ladderFilledText = ladderLongFilledCount > 0 ? "L " + str.tostring(ladderLongFilledCount) + "/3" : ladderShortFilledCount > 0 ? "S " + str.tostring(ladderShortFilledCount) + "/3" : "0/3"
    float ladderAvgEntry = ladderAnyOpen ? strategy.position_avg_price : na
    ladderSoftStopText = ladderLongOpen ? f_price(longSoftStopPx) : ladderShortOpen ? f_price(shortSoftStopPx) : "L " + f_price(longSoftStopPx) + " / S " + f_price(shortSoftStopPx)
    ladderEmergencyStopText = ladderLongOpen ? f_price(longEmergencyStopPx) : ladderShortOpen ? f_price(shortEmergencyStopPx) : "L " + f_price(longEmergencyStopPx) + " / S " + f_price(shortEmergencyStopPx)
    activeRungsText = (gl1Open ? ID_GL1 + " " : "") + (gl2Open ? ID_GL2 + " " : "") + (gl3Open ? ID_GL3 + " " : "") + (gs1Open ? ID_GS1 + " " : "") + (gs2Open ? ID_GS2 + " " : "") + (gs3Open ? ID_GS3 + " " : "")
    activeRungsText := str.length(activeRungsText) > 0 ? activeRungsText : "NONE"
    targetText = ladderLongOpen ? f_price(longTargetPx) : ladderShortOpen ? f_price(shortTargetPx) : "L " + f_price(longTargetPx) + " / S " + f_price(shortTargetPx)
    rtCostFilterText = useFeeAwareSizing ? "L " + (longL1FeeOk ? "1" : "-") + (longL2FeeOk ? "2" : "-") + (longL3FeeOk ? "3" : "-") + " / S " + (shortL1FeeOk ? "1" : "-") + (shortL2FeeOk ? "2" : "-") + (shortL3FeeOk ? "3" : "-") : "OFF"

    f_renderInfoRow(dash, 22, "LADDER MODE", ladderOrderMode ? entryMode : "OFF")
    f_renderInfoRow(dash, 23, "LADDER LEVELS", f_num(ladderSd1) + " / " + f_num(ladderSd2) + " / " + f_num(ladderSd3) + " SD")
    f_renderInfoRow(dash, 24, "LADDER RISK", f_num(basketRiskPct) + "% / Max " + f_num(maxNotionalPct) + "%")
    f_renderInfoRow(dash, 25, "LADDER SIDE", ladderActiveSide)
    f_renderInfoRow(dash, 26, "LADDER FILLED", ladderFilledText)
    f_renderInfoRow(dash, 27, "LADDER AVG", f_price(ladderAvgEntry))
    f_renderInfoRow(dash, 28, "LADDER SOFT", ladderSoftStopText)
    f_renderInfoRow(dash, 29, "LADDER EMERG", ladderEmergencyStopText)

    f_renderInfoRow(dash, 30, "BIAS L", str.tostring(longBiasScore) + "/" + str.tostring(longBiasMinScore) + " " + f_boolText(allowLongMeanRev))
    f_renderInfoRow(dash, 31, "BIAS S", str.tostring(shortBiasScore) + "/" + str.tostring(shortBiasMinScore) + " " + f_boolText(allowShortMeanRev))
    f_renderInfoRow(dash, 32, "DXY", dxyBearishForGold ? "BEARISH GOLD+" : dxyBullishForGold ? "BULLISH GOLD-" : "NEUTRAL")
    f_renderInfoRow(dash, 33, "US10Y", us10yBearishForGold ? "BEARISH GOLD+" : us10yBullishForGold ? "BULLISH GOLD-" : "NEUTRAL")
    f_renderInfoRow(dash, 34, "ENTRY MODE", entryMode)
    f_renderInfoRow(dash, 35, "LADDER", f_boolText(ladderOrderMode) + " " + ladderActiveSide)
    f_renderInfoRow(dash, 36, "TARGET", targetText)
    f_renderInfoRow(dash, 37, "SOFT STOP", ladderSoftStopText)
    f_renderInfoRow(dash, 38, "EMERG STOP", ladderEmergencyStopText)
    f_renderInfoRow(dash, 39, "ACTIVE RUNGS", activeRungsText)
    f_renderInfoRow(dash, 40, "BASKET RISK", "$" + f_num(basketRiskDollar) + " / cap $" + f_num(maxNotionalDollar))
    f_renderInfoRow(dash, 41, "RT COST FILTER", rtCostFilterText)

    f_renderInfoRow(dash, 42, "NET PROFIT", f_pct(netProfitPct))
    f_renderInfoRow(dash, 43, "MAX DD", f_pct(math.abs(maxDrawdownPct)))
    f_renderInfoRow(dash, 44, "CLOSED", str.tostring(strategy.closedtrades))
    f_renderInfoRow(dash, 45, "WIN RATE", f_pct(winRatePct))
    f_renderInfoRow(dash, 46, "SHARPE", "Sharpe: read from Strategy Tester (official)")
    f_renderInfoRow(dash, 47, "CUSTOM SHARPE", f_num(customSharpe))

// Changelog:
// - Added asymmetric HTF/DXY/US10Y bias scoring that reuses finalBuyBias/finalSellBias.
// - Replaced legacy ladder IDs with explicit GL_2_0/GL_2_5/GL_3_0 and GS_2_0/GS_2_5/GS_3_0 rung IDs.
// - Added 3-level SD ladder entries, fee-aware filters, risk-based basket sizing, target/partial/soft/emergency exits, stale exits, and explicit flip handling.
// - Preserved the 14-indicator dashboard logic, tactical fallback entries, legacy alerts, and existing visual style while adding ladder dashboard rows and granular grid alerts.
